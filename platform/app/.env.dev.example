# NOTE: docker doesn't like quotes in env var values
OPENAI_BASE_URL=xxxx
AZURE_OPENAI_ENDPOINT=xxx
CO_API_URL=xxxx
ANTHROPIC_BASE_URL=xxxx

OPENAI_API_KEY=xxxx
CO_API_KEY=xxxx
ANTHROPIC_API_KEY=xxxx
OPENAI_AGENTS_DISABLE_TRACING=1

LANGFUSE_SECRET_KEY=xxxx
LANGFUSE_PUBLIC_KEY=xxxx

# Assure same as platform/observability/.env.dev
# Currently communication not over docker network
LANGFUSE_BASE_URL=http://host.containers.internal:3001 


# --------------------------------------
# PORTS
# --------------------------------------

# weaviate
WEAVIATE_HTTP_PORT=8080
WEAVIATE_HTTP_HOST=weaviate
WEAVIATE_HTTP_SECURE=false
WEAVIATE_GRPC_PORT=50051
WEAVIATE_GRPC_HOST=weaviate
WEAVIATE_GRPC_SECURE=false


# ollama
OLLAMA_PORT=11434

# shopping-assistant
SHOPPING_ASSISTANT_PORT=8010

# ecom-backend
ECOM_API_PORT=8000


IMAGE_TAG=dev
REGISTRY=xxx/ # or keep blank for no remote repo (end with slash)